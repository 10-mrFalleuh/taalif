# ─── Base de données PostgreSQL ─────────────────────────────────
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:motdepasse@localhost:5432/taalif_db"

# ─── NextAuth.js ─────────────────────────────────────────────────
# Secret aléatoire fort (génère avec : openssl rand -base64 32)
NEXTAUTH_SECRET="votre-secret-nextauth-tres-long-et-aleatoire"
# URL de base en développement
NEXTAUTH_URL="http://localhost:3000"

# ─── Email (Nodemailer) ──────────────────────────────────────────
# Pour la vérification d'email et le mot de passe oublié
# Exemple avec Gmail (activer "App passwords" dans les paramètres Google)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="votre-email@gmail.com"
EMAIL_SERVER_PASSWORD="votre-app-password-gmail"
EMAIL_FROM="TAALIF <no-reply@taalif.sn>"

# ─── Stockage fichiers ───────────────────────────────────────────
# En développement : stockage local (dossier public/uploads)
UPLOAD_DIR="./public/uploads"
# URL publique pour accéder aux fichiers uploadés
NEXT_PUBLIC_UPLOAD_URL="/uploads"

# ─── Cloudinary (Production - optionnel) ─────────────────────────
# Décommenter pour utiliser Cloudinary en production
# CLOUDINARY_CLOUD_NAME="votre-cloud-name"
# CLOUDINARY_API_KEY="votre-api-key"
# CLOUDINARY_API_SECRET="votre-api-secret"

# ─── AWS S3 (Production - optionnel) ─────────────────────────────
# Alternative à Cloudinary pour le stockage de fichiers
# AWS_ACCESS_KEY_ID="votre-access-key"
# AWS_SECRET_ACCESS_KEY="votre-secret-key"
# AWS_REGION="eu-west-3"
# AWS_S3_BUCKET="taalif-uploads"

# ─── Application ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="TAALIF"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Rate Limiting (Upstash Redis - optionnel) ───────────────────
# Pour le rate limiting en production
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."
